# =============================================================================
# Clever AI Gate — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# WARNING: Never commit .env to version control!
# =============================================================================

# --- Server ---
PORT=8080
GIN_MODE=debug  # "debug" for development, "release" for production

# --- Database ---
# PostgreSQL connection string
DATABASE_URL=
# --- Security ---
# AES-256-GCM master key for encrypting provider API keys (64 hex chars = 32 bytes)
# Generate with: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=1dc135605771609aaa32f097415c05832980dfaf2f837a47d9ef89fb084c6b96

# Admin API key for management endpoints (minimum 16 characters)
# Generate with: openssl rand -hex 24
ADMIN_API_KEY=30a135aa79f0b839d8fdeecbe41d4506ef596875d6823132

# --- Cache ---
CACHE_MAX_SIZE_MB=256
CACHE_NUM_COUNTERS=1000000

# --- Telemetry ---
TELEMETRY_FLUSH_INTERVAL=2s
TELEMETRY_BATCH_SIZE=500
TELEMETRY_QUEUE_SIZE=10000

# --- Transport (Advanced) ---
MAX_IDLE_CONNS=5000
MAX_IDLE_CONNS_PER_HOST=500
IDLE_CONN_TIMEOUT=120s
DIAL_TIMEOUT=2s
KEEP_ALIVE=90s

# --- Rate Limiting ---
DEFAULT_RATE_LIMIT_RPM=60

# --- Logging ---
LOG_LEVEL=debug  # "debug", "info", "warn", "error"
